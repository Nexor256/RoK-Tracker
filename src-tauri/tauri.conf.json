{
  "productName": "RoK Tracker Suite",
  "version": "1.0.0",
  "identifier": "com.roktracker.suite",
  "build": {
    "beforeDevCommand": "cd gui_frontend && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd gui_frontend && npm run build",
    "frontendDist": "../gui_frontend/dist/spa"
  },
  "app": {
    "windows": [
      {
        "title": "RoK Tracker Suite",
        "width": 1150,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "x": 350,
        "y": 20
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/scanner_sidecar"],
    "resources": {
      "../config.json": "config.json",
      "../deps/inputs": "deps/inputs",
      "../deps/ch_templates": "deps/ch_templates"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1MzhFNTYwREMzNzUxQUYKUldTdlVUZmNZT1U0UllWMTljZkJDZnVOWUh1bkhHbkVKUnE4VTBuT3VZTE9aTys4N0ZVS2pncVgK",
      "endpoints": [
        "https://github.com/Nexor255/RoK-Tracker/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
